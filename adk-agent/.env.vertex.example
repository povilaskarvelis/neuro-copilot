# Vertex AI mode (recommended for hackathon deployment)
GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Optional runtime tuning
ADK_NATIVE_MODEL="gemini-3.1-flash-lite-preview"
ADK_SYNTHESIZER_MODEL="gemini-2.5-pro"
ADK_ROUTER_MODEL="gemini-3.1-flash-lite-preview"
ADK_NATIVE_PLAN_MAX_ITERS="1"
ADK_NATIVE_EVIDENCE_MAX_ITERS="3"
ADK_NATIVE_PREFER_BIGQUERY="1"

# Optional tool-source metadata
OPENALEX_MAILTO=""
CONTACT_EMAIL=""
HF_TOKEN=""
HF_DATASET_PUBMEDQA="qiaojin/PubMedQA"
HF_DATASET_BIOASQ="kroshan/BioASQ"
HF_DATASET_GPQA="Idavidrein/gpqa"

# Optional BigQuery integration
BQ_PROJECT_ID="your-gcp-project-id"
BQ_LOCATION="US"
# Comma-separated allowlist, e.g. "your-gcp-project-id.shared_dataset"
BQ_DATASET_ALLOWLIST=""
# Cost guardrail (bytes billed per query)
BQ_MAX_BYTES_BILLED="5000000000"
