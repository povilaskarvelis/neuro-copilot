# Vertex AI mode (recommended for hackathon deployment)
GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# Optional runtime tuning
ADK_NATIVE_MODEL="gemini-2.5-flash"
ADK_NATIVE_PLAN_MAX_ITERS="1"
ADK_NATIVE_EVIDENCE_MAX_ITERS="3"

# Optional tool-source metadata
OPENALEX_MAILTO=""
CONTACT_EMAIL=""
